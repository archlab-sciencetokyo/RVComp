+static void format_local_timestamp(char *timestamp_buf, time_t now)
+{
+	static const char month_names[] =
+		"JanFebMarAprMayJunJulAugSepOctNovDec";
+	struct tm tm;
+
+	if (!localtime_r(&now, &tm)
+	 || tm.tm_mon < 0 || tm.tm_mon > 11
+	 || tm.tm_mday < 1 || tm.tm_mday > 31
+	 || tm.tm_hour < 0 || tm.tm_hour > 23
+	 || tm.tm_min < 0 || tm.tm_min > 59
+	 || tm.tm_sec < 0 || tm.tm_sec > 60
+	) {
+		strcpy(timestamp_buf, "Jan  1 00:00:00");
+		return;
+	}
+
+	memcpy(timestamp_buf, month_names + tm.tm_mon * 3, 3);
+	sprintf(timestamp_buf + 3, " %2u %02u:%02u:%02u",
+		tm.tm_mday,
+		tm.tm_hour,
+		tm.tm_min,
+		tm.tm_sec);
 }
 
