# Early camera bring-up for initramfs.

module_available() {
    mod_name="$1"
    mod_file="$(find /lib/modules -type f \( -name "${mod_name}.ko" -o -name "${mod_name}.ko.*" \) -print -quit 2>/dev/null)"
    [ -n "${mod_file}" ]
}

if ! module_available rvcomp_camera; then
    echo "[init] rvcomp_camera module not present; skipping"
    exit 0
fi

echo "[init] loading rvcomp_camera"
if modprobe rvcomp_camera >/dev/null 2>&1; then
    echo "[init] rvcomp_camera loaded"
else
    echo "[init] rvcomp_camera modprobe failed"
fi

exit 0
